# =============================================================================
# .env.testing.example — isolated MySQL test environment template
# =============================================================================
#
# Purpose:
#   This file is the canonical template for `.env.testing`, used by
#   `php artisan test` and `phpunit` runs to point at the isolated
#   `jahongirnewapp_test` database — NEVER the production `jahongir` DB.
#
# Setup:
#   1. Copy:   cp .env.testing.example .env.testing
#   2. Fill in DB_PASSWORD (copy from production .env, same MySQL user)
#   3. Fill in APP_KEY    (copy from production .env, OR generate new)
#   4. Verify before running tests:
#        php artisan tinker --env=testing \
#          --execute="echo DB::connection()->getDatabaseName();"
#      MUST print `jahongirnewapp_test`. If it prints `jahongir`, abort.
#
# Hard rules:
#   - NEVER point DB_DATABASE at the production database (`jahongir`).
#   - NEVER commit `.env.testing` to git — only this `.example` file.
#   - NEVER use real mailer / queue / cache backends in testing.
#   - NEVER set APP_ENV to anything other than `testing`.
#
# See also:
#   - phpunit.xml — has the same DB target as runtime override
#   - docs/architecture/yurt-departures/PHASE_0_ARCHITECTURE_LOCK.md §13
#
# =============================================================================

APP_NAME=Laravel
APP_ENV=testing
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# -----------------------------------------------------------------------------
# Database — ISOLATED test database, NEVER production
# -----------------------------------------------------------------------------
# NEVER point this at production database (`jahongir`).
# Required for isolated MySQL test runs that exercise lockForUpdate(),
# whereRaw subqueries, FK constraints, and other MySQL-specific behavior
# that SQLite would silently misrepresent.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=jahongirnewapp_test
DB_USERNAME=jahongirapp
DB_PASSWORD=

# -----------------------------------------------------------------------------
# Backends — all in-memory / null to prevent any side effects on real systems
# -----------------------------------------------------------------------------
CACHE_DRIVER=array
SESSION_DRIVER=array
QUEUE_CONNECTION=sync
MAIL_MAILER=array

# -----------------------------------------------------------------------------
# Disabled optional services
# -----------------------------------------------------------------------------
TELESCOPE_ENABLED=false
PULSE_ENABLED=false
HORIZON_ENABLED=false

# -----------------------------------------------------------------------------
# External integrations — all placeholders, never real credentials
# -----------------------------------------------------------------------------
# Telegram bots: webhooks must NOT fire from test runs. If your test
# constructs a TelegramBot model, use placeholder tokens only.
TELEGRAM_BOT_TOKEN=test-placeholder

# Beds24: refresh token placeholder — do not use real tokens here.
BEDS24_API_V2_REFRESH_TOKEN=test-placeholder

# Octobank: never hit real Octobank from tests. Mock the client.
OCTO_SHOP_ID=00000
OCTO_SECRET=test-placeholder

# WhatsApp Cloud API placeholder
WHATSAPP_TOKEN=test-placeholder

# -----------------------------------------------------------------------------
# Performance flags
# -----------------------------------------------------------------------------
BCRYPT_ROUNDS=4
LOG_CHANNEL=stack
LOG_LEVEL=debug
